# Example environment for tunnel-trigger + tunnel-detect on the Pi.
# Copy to /etc/tunnel-detect/tunnel-detect.env on the device, edit values, then:
#   sudo chmod 600 /etc/tunnel-detect/tunnel-detect.env
# Do not commit real credentials or bucket names from production.

# AWS
AWS_REGION=us-east-1
S3_BUCKET=tunnel-images-REPLACE_ACCOUNT_ID

# Local storage (trigger server + queue + daemon)
LOCAL_STORAGE_PATH=/data/tunnel/images
UPLOAD_QUEUE_DB=/data/tunnel/queue.db
MAX_LOCAL_STORAGE_MB=5000

# Image processing
IMAGE_MAX_DIMENSION=1920
IMAGE_JPEG_QUALITY=85

# Capture
CAPTURE_TIMEOUT_S=5.0

# Upload worker
UPLOAD_TIMEOUT_S=10.0
UPLOAD_WORKER_INTERVAL_S=10.0
UPLOAD_WORKER_BACKOFF_MAX_S=300.0
UPLOAD_MAX_RETRIES=5

# FastAPI trigger server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

LOG_LEVEL=INFO

# Cameras: shared credentials interpolated into rtsp:// URLs in CAMERAS_JSON
CAMERA_USER=admin
CAMERA_PASS=changeme
CAMERAS_JSON=/etc/tunnel-detect/cameras.json
RTSP_TRANSPORT=tcp
CAMERA_TIMEOUT_MS=5000

# Vehicle detection daemon (working dir: camera-system/model)
YOLO_MODEL=yolov8n.onnx
DETECTION_CONFIDENCE=0.5
BURST_INTERVAL=1.0
BURST_MAX_DURATION=15
BURST_EXIT_MISSES=3
SCAN_RESULTS_DIR=/data/tunnel/scans

# Set to 0 on detect_daemon only if rolling back to direct scan_uploader.
USE_UPLOAD_QUEUE=1

# Optional SageMaker / endpoint tooling on the Pi (uncomment if used)
# MODEL_ARTIFACT_S3_URI=s3://your-bucket/model.tar.gz
# SAGEMAKER_IMAGE_URI=
# SAGEMAKER_ENDPOINT_NAME=tunnel-damage-detection
