{
  "name": "ezcarrental",
  "version": "1.0.0",
  "description": "AI-powered car rental platform",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "deploy:dev": "./deploy/deploy.sh dev",
    "deploy:staging": "./deploy/deploy.sh staging",
    "deploy:prod": "./deploy/deploy.sh production",
    "cdk": "cdk",
    "cdk:deploy": "cdk deploy",
    "cdk:deploy:dev": "cdk deploy --context environment=dev",
    "cdk:deploy:staging": "cdk deploy --context environment=staging",
    "cdk:deploy:prod": "cdk deploy --context environment=production",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:destroy": "cdk destroy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "aws-cdk-lib": "^2.150.0",
    "axios": "^1.3.0",
    "constructs": "^10.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "stripe": "^14.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^3.1.0",
    "aws-cdk": "^2.150.0",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "jest": "^29.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^4.9.5",
    "vite": "^4.1.0"
  },
  "keywords": [
    "car-rental",
    "ai",
    "react",
    "aws"
  ],
  "author": "EZ Car Rental Team",
  "license": "MIT"
}
